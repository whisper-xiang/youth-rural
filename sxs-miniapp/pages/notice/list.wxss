.page {
  min-height: 100vh;
  background: #f7f8fa;
}

/* 顶部操作栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.btn-add {
  font-size: 26rpx;
  color: #fff;
  background: #2b5aed;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

/* 顶部分类标签 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: color 0.3s ease;
}
.tab.active {
  color: #2b5aed;
  font-weight: 600;
}
.tab.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #2b5aed;
  border-radius: 3rpx;
}

/* 通知列表 */
.list {
  padding: 20rpx 24rpx;
}
.notice-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}
.notice-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}
.notice-item.unread {
  background: linear-gradient(135deg, #fafbff 0%, #f8faff 100%);
  border-left: 6rpx solid #2b5aed;
}
.notice-dot {
  position: absolute;
  left: 16rpx;
  top: 32rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff4d4f;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 77, 79, 0.1);
}
.notice-content {
  flex: 1;
  overflow: hidden;
  padding-left: 8rpx;
}
.notice-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}
.notice-tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}
.tag-notice {
  background: #e6f7ff;
  color: #1890ff;
}
.tag-policy {
  background: #fff7e6;
  color: #fa8c16;
}
.tag-activity {
  background: #f6ffed;
  color: #52c41a;
}
.notice-top {
  font-size: 20rpx;
  color: #ff4d4f;
  background: #fff2f0;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}
.notice-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}
.notice-item.unread .notice-title {
  font-weight: 700;
  color: #2b5aed;
}
.notice-summary {
  font-size: 26rpx;
  color: #8c8c8c;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.notice-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.notice-source {
  font-size: 24rpx;
  color: #2b5aed;
  font-weight: 500;
}
.notice-time {
  font-size: 24rpx;
  color: #999;
}
.notice-arrow {
  font-size: 36rpx;
  color: #d9d9d9;
  margin-left: 16rpx;
  margin-top: 8rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
}
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}
.empty-text {
  font-size: 30rpx;
  color: #8c8c8c;
  font-weight: 500;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 24rpx;
  font-size: 26rpx;
  color: #999;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx;
  color: #8c8c8c;
  font-size: 28rpx;
}
