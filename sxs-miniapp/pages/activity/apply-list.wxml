<view class="page">
  <!-- 顶部操作栏 -->
  <view class="header">
    <view class="header-title">我的项目</view>
    <view class="btn-add" wx:if="{{canCreate}}" bindtap="createNew">+ 发起项目申报</view>
  </view>

  <!-- 项目列表 -->
  <view class="list" wx:if="{{list.length > 0}}">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}" data-status="{{item.status}}">
      <view class="card-header">
        <view class="card-title">{{item.title}}</view>
        <view class="card-status status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="card-info">
        <text class="info-item">负责人：{{item.leader_name}}</text>
        <text class="info-item">成员：{{item.members_count}}人</text>
      </view>
      <view class="card-info">
        <text class="info-item">实践地点：{{item.target_area}}</text>
      </view>
      <view class="card-footer">
        <text class="card-time">{{item.createTime}}</text>
        <view class="card-actions" wx:if="{{item.status === 'draft' || item.status === 'pending'}}" catchtap="goEdit" data-id="{{item.id}}">
          <text class="edit-btn">编辑</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无项目记录</view>
    <view class="empty-hint" wx:if="{{canCreate}}">点击右上角"发起申报"开始</view>
    <view class="empty-hint" wx:else>当前角色暂无相关项目</view>
  </view>
</view>
